{
 "type": "scene",
 "id": "main",
 "root": {
  "type": "column",
  "id": "root",
  "style": {
   "background": "transparent",
   "width": "100%",
   "height": "100%",
   "padding": 10
  },
  "layout": {
   "justify": "center"
  },
  "children": [
   {
    "type": "card",
    "id": "hud",
    "style": {
     "background": "rgba(28,28,30,0.92)",
     "borderRadius": 22,
     "padding": 14,
     "gap": 8
    },
    "children": [
     {
      "type": "row",
      "id": "top",
      "style": {
       "gap": 8
      },
      "layout": {
       "align": "center"
      },
      "children": [
       {
        "type": "icon",
        "id": "ic",
        "icon": "sun",
        "size": 16,
        "style": {
         "color": "#0a84ff"
        }
       },
       {
        "type": "text",
        "id": "label",
        "text": "Focus session",
        "style": {
         "fontSize": 13,
         "fontWeight": 700,
         "color": "#ffffff",
         "flexGrow": 1
        }
       }
      ]
     },
     {
      "type": "text",
      "id": "time",
      "text": "{{ state.mins }}:00",
      "style": {
       "fontSize": 34,
       "fontWeight": 800,
       "color": "#ffffff",
       "textAlign": "center"
      }
     },
     {
      "type": "button",
      "id": "toggleBtn",
      "text": "{{ state.running ? \"Pause\" : \"Start\" }}",
      "onPress": {
       "name": "toggle"
      },
      "style": {
       "background": "#0a84ff"
      }
     }
    ],
    "drag": true
   }
  ]
 }
}