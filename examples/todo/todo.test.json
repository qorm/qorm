{
  "qorm": "0.1",
  "type": "test",
  "name": "todo test",
  "scene": {
    "type": "scene",
    "id": "todo",
    "state": { "tasks": [] },
    "root": {
      "type": "column",
      "id": "root",
      "children": [
        {
          "type": "text",
          "id": "title",
          "value": "Todo"
        },
        {
          "type": "button",
          "id": "add_task_button",
          "text": "Add task",
          "on": {
            "press": {
              "type": "state.append",
              "path": "tasks",
              "value": { "title": "New task" }
            }
          }
        }
      ]
    }
  },
  "steps": [
    {
      "type": "simulate_event",
      "target": { "id": "add_task_button" },
      "event": "press"
    }
  ],
  "assertions": [
    {
      "type": "state_equals",
      "path": "tasks[0].title",
      "value": "New task"
    }
  ]
}
