{ "type": "scene", "id": "profile", "root": { "type": "scaffold", "children": [
  { "type": "appbar", "title": "Profile" },
  { "type": "column", "style": { "padding": 20, "gap": 12 }, "children": [
    { "type": "row", "style": { "gap": 14 }, "layout": { "align": "center" }, "children": [
      { "type": "avatar", "text": "{{ route.name }}", "style": { "width": 56, "height": 56 } },
      { "type": "column", "style": { "gap": 2 }, "children": [
        { "type": "text", "text": "{{ route.name }}", "style": { "fontWeight": 700, "fontSize": 20 } },
        { "type": "text", "text": "{{ route.role }}", "style": { "color": "#8e8e93", "fontSize": 13 } }
      ]}
    ]},
    { "type": "text", "text": "User id: {{ route.userId }}", "style": { "color": "#8e8e93", "fontSize": 13 } },
    { "type": "button", "text": "Back", "onPress": { "type": "invoke", "name": "back" }, "style": { "background": "#8e8e93", "color": "#fff", "padding": 14, "borderRadius": 10, "fontWeight": 700 } }
  ]}
]}}
