{
  "type": "scene",
  "id": "main",
  "root": {
    "type": "column",
    "id": "root",
    "style": { "gap": 16, "padding": 20 },
    "children": [
      { "type": "text", "id": "title", "text": "Responsive Layout", "style": { "color": "var(--label)", "fontSize": 24, "fontWeight": "bold" } },
      { "type": "text", "id": "viewport-readout", "text": "viewport: {{ viewport.width }} x {{ viewport.height }} ({{ viewport.orientation }})", "style": { "color": "var(--label2)", "fontSize": 13 } },
      { "type": "text", "id": "note", "text": "{{ state.note }}" },
      {
        "type": "when",
        "id": "layout-switch",
        "condition": "{{ viewport.width >= 768 }}",
        "then": {
          "type": "row",
          "id": "cards-wide",
          "style": { "gap": 12 },
          "children": [
            { "type": "card", "id": "card-a-wide", "style": { "flexGrow": 1, "padding": 16, "gap": 6, "borderRadius": 12, "borderWidth": 1, "borderColor": "var(--sep)" }, "children": [
              { "type": "text", "id": "card-a-wide-title", "text": "Overview", "style": { "color": "var(--label)", "fontWeight": "bold" } },
              { "type": "text", "id": "card-a-wide-body", "text": "Wide viewport: the three cards sit side by side in a row.", "style": { "color": "var(--label2)" } }
            ] },
            { "type": "card", "id": "card-b-wide", "style": { "flexGrow": 1, "padding": 16, "gap": 6, "borderRadius": 12, "borderWidth": 1, "borderColor": "var(--sep)" }, "children": [
              { "type": "text", "id": "card-b-wide-title", "text": "Activity", "style": { "color": "var(--label)", "fontWeight": "bold" } },
              { "type": "text", "id": "card-b-wide-body", "text": "The when node picked its then branch because viewport.width >= 768.", "style": { "color": "var(--label2)" } }
            ] },
            { "type": "card", "id": "card-c-wide", "style": { "flexGrow": 1, "padding": 16, "gap": 6, "borderRadius": 12, "borderWidth": 1, "borderColor": "var(--sep)" }, "children": [
              { "type": "text", "id": "card-c-wide-title", "text": "Details", "style": { "color": "var(--label)", "fontWeight": "bold" } },
              { "type": "text", "id": "card-c-wide-body", "text": "Shrink the window under 768px to collapse into a column.", "style": { "color": "var(--label2)" } }
            ] }
          ]
        },
        "else": {
          "type": "column",
          "id": "cards-narrow",
          "style": { "gap": 12 },
          "children": [
            { "type": "card", "id": "card-a-narrow", "style": { "padding": 16, "gap": 6, "borderRadius": 12, "borderWidth": 1, "borderColor": "var(--sep)" }, "children": [
              { "type": "text", "id": "card-a-narrow-title", "text": "Overview", "style": { "color": "var(--label)", "fontWeight": "bold" } },
              { "type": "text", "id": "card-a-narrow-body", "text": "Narrow (or unknown) viewport: the cards stack in a column.", "style": { "color": "var(--label2)" } }
            ] },
            { "type": "card", "id": "card-b-narrow", "style": { "padding": 16, "gap": 6, "borderRadius": 12, "borderWidth": 1, "borderColor": "var(--sep)" }, "children": [
              { "type": "text", "id": "card-b-narrow-title", "text": "Activity", "style": { "color": "var(--label)", "fontWeight": "bold" } },
              { "type": "text", "id": "card-b-narrow-body", "text": "The when node fell back to its else branch (viewport.width < 768).", "style": { "color": "var(--label2)" } }
            ] },
            { "type": "card", "id": "card-c-narrow", "style": { "padding": 16, "gap": 6, "borderRadius": 12, "borderWidth": 1, "borderColor": "var(--sep)" }, "children": [
              { "type": "text", "id": "card-c-narrow-title", "text": "Details", "style": { "color": "var(--label)", "fontWeight": "bold" } },
              { "type": "text", "id": "card-c-narrow-body", "text": "Widen the window past 768px to switch back to a row.", "style": { "color": "var(--label2)" } }
            ] }
          ]
        }
      },
      {
        "type": "when",
        "id": "orientation-switch",
        "condition": "{{ viewport.orientation == 'portrait' }}",
        "then": { "type": "badge", "id": "orient-portrait", "text": "portrait" },
        "else": { "type": "badge", "id": "orient-landscape", "text": "landscape (or unknown)" }
      }
    ]
  }
}
