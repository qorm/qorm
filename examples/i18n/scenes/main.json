{
 "type": "scene",
 "id": "main",
 "root": {
  "type": "column",
  "id": "root",
  "style": {
   "background": "var(--bg)",
   "padding": 32,
   "gap": 12
  },
  "layout": {
   "width": "fill",
   "height": "fill",
   "align": "center",
   "justify": "center"
  },
  "children": [
   {
    "type": "text",
    "id": "title",
    "text": "{{ t.title }}",
    "style": {
     "color": "var(--label)",
     "fontSize": 28,
     "fontWeight": 800,
     "textAlign": "center"
    }
   },
   {
    "type": "text",
    "id": "subtitle",
    "text": "{{ t.subtitle }}",
    "style": {
     "color": "var(--label2)",
     "fontSize": 15,
     "textAlign": "center"
    }
   },
   {
    "type": "text",
    "id": "t_greeting",
    "text": "{{ t.greeting }}",
    "style": {
     "fontSize": 16,
     "color": "var(--label)"
    }
   },
   {
    "type": "text",
    "id": "t_cart",
    "text": "{{ t.cart }}",
    "style": {
     "fontSize": 16,
     "color": "var(--label2)"
    }
   },
   {
    "type": "text",
    "id": "t_price",
    "text": "{{ t.price }}",
    "style": {
     "fontSize": 16,
     "fontWeight": 700,
     "color": "var(--label)"
    }
   },
   {
    "type": "button",
    "id": "lang",
    "label": "{{ t.switch }}",
    "style": {
     "background": "var(--accent)",
     "color": "var(--on-accent)",
     "fontWeight": 700,
     "width": 200,
     "height": 44,
     "borderRadius": 12
    },
    "onPress": {
     "type": "invoke",
     "name": "toggleLocale",
     "args": {
      "locale": "{{state.locale}}"
     }
    }
   }
  ]
 }
}