{
  "type": "scene",
  "id": "main",
  "root": {
    "type": "scroll",
    "id": "root",
    "style": {
      "background": "var(--qorm-token-color-bg)",
      "padding": 20,
      "gap": 16
    },
    "layout": {
      "width": "fill",
      "height": "fill"
    },
    "children": [
      {
        "type": "card",
        "id": "header",
        "style": {
          "gap": 12
        },
        "children": [
          {
            "type": "row",
            "id": "profile",
            "style": {
              "gap": 12
            },
            "layout": {
              "align": "center"
            },
            "children": [
              {
                "type": "avatar",
                "id": "av",
                "initials": "{{state.name}}",
                "size": 48
              },
              {
                "type": "column",
                "id": "who",
                "style": {
                  "gap": 2
                },
                "layout": {
                  "justify": "center"
                },
                "children": [
                  {
                    "type": "text",
                    "id": "hi",
                    "text": "Hello, {{state.name}}",
                    "style": {
                      "fontSize": 18,
                      "fontWeight": 700,
                      "color": "var(--label)"
                    }
                  },
                  {
                    "type": "badge",
                    "id": "plan_badge",
                    "label": "{{state.plan}} plan"
                  }
                ]
              },
              {
                "type": "spacer",
                "id": "sp1"
              },
              {
                "type": "icon",
                "id": "gear",
                "icon": "settings",
                "style": {
                  "fontSize": 22
                }
              }
            ]
          }
        ]
      },
      {
        "type": "grid",
        "id": "stats",
        "columns": 3,
        "style": {
          "gap": 12
        },
        "children": [
          {
            "type": "card",
            "id": "s1",
            "style": {
              "gap": 4
            },
            "children": [
              {
                "type": "text",
                "text": "1.2k",
                "style": {
                  "fontSize": 22,
                  "fontWeight": 800,
                  "color": "var(--qorm-token-color-info)"
                }
              },
              {
                "type": "text",
                "text": "Views",
                "style": {
                  "fontSize": 12,
                  "color": "var(--label2)"
                }
              }
            ]
          },
          {
            "type": "card",
            "id": "s2",
            "style": {
              "gap": 4
            },
            "children": [
              {
                "type": "text",
                "text": "348",
                "style": {
                  "fontSize": 22,
                  "fontWeight": 800,
                  "color": "var(--qorm-token-color-success)"
                }
              },
              {
                "type": "text",
                "text": "Likes",
                "style": {
                  "fontSize": 12,
                  "color": "var(--label2)"
                }
              }
            ]
          },
          {
            "type": "card",
            "id": "s3",
            "style": {
              "gap": 4
            },
            "children": [
              {
                "type": "text",
                "text": "27",
                "style": {
                  "fontSize": 22,
                  "fontWeight": 800,
                  "color": "var(--qorm-token-color-warning)"
                }
              },
              {
                "type": "text",
                "text": "New",
                "style": {
                  "fontSize": 12,
                  "color": "var(--label2)"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "tabs",
        "id": "tabs",
        "tabs": [
          "Form",
          "Status"
        ],
        "children": [
          {
            "type": "card",
            "id": "form",
            "style": {
              "gap": 14
            },
            "children": [
              {
                "type": "text",
                "text": "Display name",
                "style": {
                  "fontSize": 13,
                  "fontWeight": 600,
                  "color": "var(--label)"
                }
              },
              {
                "type": "input",
                "id": "name_in",
                "value": "{{state.name}}",
                "placeholder": "Your name",
                "onChange": {
                  "type": "invoke",
                  "name": "noop"
                },
                "style": {
                  "background": "var(--surface)",
                  "height": 40,
                  "padding": {
                    "left": 12
                  },
                  "borderRadius": 8,
                  "borderWidth": 1,
                  "borderColor": "var(--sep)"
                }
              },
              {
                "type": "text",
                "text": "Bio",
                "style": {
                  "fontSize": 13,
                  "fontWeight": 600,
                  "color": "var(--label)"
                }
              },
              {
                "type": "textarea",
                "id": "bio_in",
                "value": "{{state.bio}}",
                "rows": 3,
                "style": {
                  "background": "var(--surface)",
                  "padding": 10,
                  "borderRadius": 8,
                  "borderWidth": 1,
                  "borderColor": "var(--sep)"
                }
              },
              {
                "type": "text",
                "text": "Plan",
                "style": {
                  "fontSize": 13,
                  "fontWeight": 600,
                  "color": "var(--label)"
                }
              },
              {
                "type": "select",
                "id": "plan_sel",
                "value": "{{state.plan}}",
                "options": [
                  {
                    "value": "free",
                    "label": "Free"
                  },
                  {
                    "value": "pro",
                    "label": "Pro"
                  },
                  {
                    "value": "team",
                    "label": "Team"
                  }
                ],
                "style": {
                  "background": "var(--surface)",
                  "height": 40,
                  "padding": {
                    "left": 8
                  },
                  "borderRadius": 8,
                  "borderWidth": 1,
                  "borderColor": "var(--sep)"
                }
              },
              {
                "type": "radio",
                "id": "billing",
                "value": "{{state.plan}}",
                "options": [
                  {
                    "value": "free",
                    "label": "Free tier"
                  },
                  {
                    "value": "pro",
                    "label": "Pro ($9/mo)"
                  },
                  {
                    "value": "team",
                    "label": "Team ($29/mo)"
                  }
                ]
              },
              {
                "type": "divider",
                "id": "d1"
              },
              {
                "type": "switch",
                "id": "notify",
                "label": "Email notifications",
                "value": "{{state.notify}}"
              },
              {
                "type": "checkbox",
                "id": "agree",
                "label": "I agree to the terms",
                "value": "{{state.agree}}"
              },
              {
                "type": "text",
                "text": "Volume: {{state.volume}}",
                "style": {
                  "fontSize": 13,
                  "color": "var(--label2)"
                }
              },
              {
                "type": "slider",
                "id": "vol",
                "value": "{{state.volume}}",
                "min": 0,
                "max": 100,
                "style": {
                  "width": "fill"
                }
              }
            ]
          },
          {
            "type": "card",
            "id": "status",
            "style": {
              "gap": 14
            },
            "children": [
              {
                "type": "text",
                "text": "Upload progress",
                "style": {
                  "fontSize": 13,
                  "fontWeight": 600,
                  "color": "var(--label)"
                }
              },
              {
                "type": "chart",
                "id": "views_chart",
                "chartType": "bar",
                "data": [
                  4,
                  8,
                  15,
                  16,
                  23,
                  42,
                  30,
                  18
                ],
                "color": "var(--qorm-token-color-success)",
                "style": {
                  "width": 300,
                  "height": 90,
                  "margin": {
                    "bottom": 8
                  }
                }
              },
              {
                "type": "chart",
                "id": "trend",
                "chartType": "area",
                "data": [
                  10,
                  12,
                  9,
                  15,
                  22,
                  18,
                  25,
                  30
                ],
                "color": "var(--qorm-token-color-info)",
                "style": {
                  "width": 300,
                  "height": 70
                }
              },
              {
                "type": "progress",
                "id": "prog",
                "value": "{{state.volume}}",
                "color": "var(--qorm-token-color-success)",
                "style": {
                  "width": "fill"
                }
              },
              {
                "type": "row",
                "id": "loading",
                "style": {
                  "gap": 10
                },
                "layout": {
                  "align": "center"
                },
                "children": [
                  {
                    "type": "spinner",
                    "id": "spin",
                    "size": 20
                  },
                  {
                    "type": "text",
                    "text": "Syncing…",
                    "style": {
                      "fontSize": 14,
                      "color": "var(--label2)"
                    }
                  }
                ]
              },
              {
                "type": "divider",
                "id": "d2"
              },
              {
                "type": "text",
                "text": "Agreed: {{state.agree}} · Notify: {{state.notify}}",
                "style": {
                  "fontSize": 13,
                  "color": "var(--label2)"
                }
              },
              {
                "type": "text",
                "id": "thanks",
                "if": "{{state.agree}}",
                "text": "Thanks for agreeing!",
                "style": {
                  "fontSize": 14,
                  "fontWeight": 700,
                  "color": "var(--qorm-token-color-success)"
                }
              },
              {
                "type": "link",
                "id": "docs",
                "label": "Read the docs →",
                "href": "https://example.com",
                "style": {
                  "color": "var(--qorm-token-color-primary)",
                  "fontSize": 14,
                  "fontWeight": 600
                }
              }
            ]
          }
        ]
      }
    ]
  }
}