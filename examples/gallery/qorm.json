{
  "type": "app",
  "id": "qorm_gallery",
  "name": "QORM Widget Gallery",
  "entry": "main",
  "version": "1.0.0",
  "globalState": {
    "schema": {
      "name": "string",
      "plan": "string",
      "volume": "number",
      "notify": "boolean",
      "agree": "boolean",
      "bio": "string"
    },
    "initial": {
      "name": "Ada",
      "plan": "pro",
      "volume": 60,
      "notify": true,
      "agree": false,
      "bio": "Building with QORM."
    }
  },
  "designTokens": {
    "color.primary": { "type": "color", "value": "#0a84ff", "enforce": true },
    "color.bg":      { "type": "color", "value": "#f2f2f7", "enforce": true },
    "color.info":    { "type": "color", "value": "#2e7df6", "enforce": true },
    "color.success": { "type": "color", "value": "#10b981", "enforce": true },
    "color.warning": { "type": "color", "value": "#f59e0b", "enforce": true },
    "spacing.md":    { "type": "number", "value": 16, "enforce": false }
  },
  "platforms": {
    "desktop": { "window": { "width": 460, "height": 820, "title": "Gallery" } }
  }
}
