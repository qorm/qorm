{ "type":"scene","id":"main","root":{"type":"scaffold","children":[
  {"type":"appbar","title":"Inbox"},
  {"type":"list","data":"{{state.items}}","renderItem":{
    "type":"swipeactions",
    "actions":[
      {"label":"Archive","icon":"inbox","color":"var(--accent)","name":"remove","args":{"id":"{{item.id}}"}},
      {"label":"Delete","icon":"trash","color":"var(--danger)","name":"remove","args":{"id":"{{item.id}}"}}
    ],
    "children":[{"type":"row","style":{"padding":16,"gap":4},"layout":{"direction":"column"},"children":[
      {"type":"text","text":"{{item.from}}","style":{"color":"var(--label)","fontWeight":700,"fontSize":16}},
      {"type":"text","text":"{{item.subject}}","style":{"color":"var(--label2)","fontSize":14}}
    ]}]
  }}
]}}
