{
 "type": "scene",
 "id": "main",
 "root": {
  "type": "scaffold",
  "id": "root",
  "children": [
   {
    "type": "appbar",
    "id": "bar",
    "label": "Native menus"
   },
   {
    "type": "column",
    "id": "page",
    "style": {
     "padding": 20,
     "gap": 14
    },
    "children": [
     {
      "type": "text",
      "id": "hint",
      "text": "Use the menu bar (File / View), right-click below, or the tray icon. The last action shows here.",
      "style": {
       "fontSize": 14,
       "color": "var(--label)"
      }
     },
     {
      "type": "card",
      "id": "out",
      "style": {
       "padding": 18,
       "gap": 6
      },
      "children": [
       {
        "type": "text",
        "id": "ol",
        "text": "LAST ACTION",
        "style": {
         "fontSize": 12,
         "fontWeight": 800,
         "color": "#8e8e93"
        }
       },
       {
        "type": "text",
        "id": "menu-out",
        "text": "—",
        "style": {
         "fontSize": 22,
         "fontWeight": 700,
         "color": "var(--accent)"
        }
       }
      ]
     },
     {
      "type": "contextmenu",
      "id": "ctx",
      "items": [
       {
        "id": "ctx-copy",
        "title": "Copy",
        "icon": "copy"
       },
       {
        "id": "ctx-paste",
        "title": "Paste",
        "icon": "clipboard"
       },
       {
        "separator": true
       },
       {
        "id": "ctx-share",
        "title": "Share",
        "icon": "share",
        "items": [
         {
          "id": "ctx-share-link",
          "title": "Copy link",
          "icon": "copy"
         },
         {
          "id": "ctx-share-mail",
          "title": "Email",
          "icon": "globe"
         }
        ]
       },
       {
        "id": "ctx-del",
        "title": "Delete",
        "icon": "x"
       }
      ],
      "children": [
       {
        "type": "card",
        "id": "ctxarea",
        "style": {
         "padding": 24,
         "background": "var(--fill)"
        },
        "children": [
         {
          "type": "text",
          "id": "ctxt",
          "text": "Right-click this area",
          "style": {
           "fontSize": 15,
           "textAlign": "center",
           "color": "var(--label2)"
          }
         }
        ]
       }
      ]
     }
    ]
   }
  ]
 }
}