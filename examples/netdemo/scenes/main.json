{
  "type": "scene",
  "id": "main",
  "root": {
    "type": "scaffold",
    "id": "root",
    "children": [
      {
        "type": "appbar",
        "id": "bar",
        "label": "Backend Demo"
      },
      {
        "type": "column",
        "id": "body",
        "style": {
          "padding": 20,
          "gap": 16
        },
        "children": [
          {
            "type": "card",
            "id": "card",
            "style": {
              "padding": 18,
              "gap": 6,
              "borderRadius": 12
            },
            "children": [
              {
                "type": "text",
                "id": "lbl",
                "text": "Cat Fact",
                "style": {
                  "fontSize": 13,
                  "fontWeight": 700,
                  "color": "var(--label2)"
                }
              },
              {
                "type": "text",
                "id": "fact",
                "text": "{{state.resp.fact}}",
                "style": {
                  "fontSize": 17,
                  "lineHeight": 1.4,
                  "color": "var(--label)"
                }
              }
            ]
          },
          {
            "type": "text",
            "id": "err",
            "text": "{{state.err}}",
            "style": {
              "fontSize": 13,
              "color": "var(--danger)"
            }
          },
          {
            "type": "button",
            "id": "go",
            "label": "New Cat Fact",
            "variant": "filled",
            "onPress": {
              "type": "invoke",
              "name": "getFact",
              "args": {}
            }
          },
          {
            "type": "divider",
            "id": "dv"
          },
          {
            "type": "text",
            "id": "camlbl",
            "text": "Hardware: Camera",
            "style": {
              "fontSize": 13,
              "fontWeight": 700,
              "color": "var(--label2)"
            }
          },
          {
            "type": "camera",
            "id": "cam",
            "value": "{{state.photo}}",
            "label": "拍照 / Take Photo"
          }
        ]
      }
    ]
  }
}