{
  "type": "scene", "id": "main",
  "root": {
    "type": "column", "id": "root",
    "style": { "background": "var(--bg)", "padding": 20, "gap": 14 },
    "layout": { "width": "fill", "height": "fill" },
    "children": [
      {
        "type": "row", "id": "head", "style": { "gap": 12 }, "layout": { "align": "center" },
        "children": [
          { "type": "text", "id": "title", "text": "Task Board", "style": { "fontSize": 22, "fontWeight": 800, "color": "var(--label)", "flexGrow": 1 } },
          { "type": "text", "id": "saving", "if": "{{ state.saving }}", "text": "Saving…", "style": { "fontSize": 13, "color": "var(--label2)" } },
          { "type": "stat", "id": "count", "label": "Total", "value": "{{ len(state.tasks) }}" }
        ]
      },
      {
        "type": "row", "id": "addrow", "style": { "gap": 8 },
        "children": [
          { "type": "input", "id": "newTitle", "value": "{{state.newTitle}}", "placeholder": "Add a task…",
            "style": { "flexGrow": 1, "height": 42, "background": "var(--surface)", "borderWidth": 1, "borderColor": "var(--sep)", "borderRadius": 8, "padding": { "left": 12 } } },
          { "type": "button", "id": "add", "label": "Add",
            "style": { "background": "var(--accent)", "color": "var(--on-accent)", "fontWeight": 700, "width": 72, "height": 42, "borderRadius": 8 },
            "onPress": { "type": "invoke", "name": "addTask", "args": { "title": "{{state.newTitle}}" } } }
        ]
      },
      {
        "type": "row", "id": "toolbar", "style": { "gap": 10 }, "layout": { "align": "center" },
        "children": [
          { "type": "segmented", "id": "filter", "value": "{{state.filter}}",
            "options": [ { "value": "all", "label": "All" }, { "value": "active", "label": "Active" }, { "value": "done", "label": "Done" } ] },
          { "type": "spacer", "id": "sp" },
          { "type": "button", "id": "sort", "label": "Sort A→Z",
            "style": { "background": "var(--fill)", "color": "var(--label)", "fontSize": 13, "padding": { "top": 8, "bottom": 8, "left": 12, "right": 12 }, "borderRadius": 8 },
            "onPress": { "type": "invoke", "name": "sortTasks", "args": {} } }
        ]
      },
      { "type": "text", "id": "error", "if": "{{ len(state.error) > 0 }}", "text": "Could not sync: {{ state.error }}",
        "style": { "background": "color-mix(in srgb,var(--danger) 15%,transparent)", "color": "var(--danger)", "fontSize": 13, "padding": 10, "borderRadius": 8 } },
      {
        "type": "list", "id": "tasklist", "data": "{{state.tasks}}",
        "renderItem": {
          "type": "row", "id": "task",
          "if": "{{ state.filter == \"all\" || (state.filter == \"active\" && !item.done) || (state.filter == \"done\" && item.done) }}",
          "style": { "background": "var(--surface)", "padding": 12, "margin": { "bottom": 8 }, "borderRadius": 10, "gap": 10 },
          "layout": { "align": "center" },
          "children": [
            { "type": "button", "id": "chk", "label": "{{ item.done ? \"●\" : \"○\" }}",
              "style": { "background": "var(--fill)", "color": "var(--success)", "width": 32, "height": 32, "borderRadius": 16, "fontSize": 16 },
              "onPress": { "type": "invoke", "name": "saveTask", "args": { "id": "{{item.id}}" } } },
            { "type": "text", "id": "t", "text": "{{item.title}}", "style": { "fontSize": 15, "color": "var(--label)", "flexGrow": 1 } },
            { "type": "badge", "id": "st", "if": "{{ item.done }}", "label": "done", "style": { "background": "color-mix(in srgb,var(--success) 15%,transparent)", "color": "var(--success)" } },
            { "type": "button", "id": "rm", "label": "×",
              "style": { "background": "color-mix(in srgb,var(--danger) 15%,transparent)", "color": "var(--danger)", "width": 28, "height": 28, "borderRadius": 14, "fontSize": 16 },
              "onPress": { "type": "invoke", "name": "removeTask", "args": { "id": "{{item.id}}" } } }
          ]
        }
      },
      { "type": "empty", "id": "none", "if": "{{ len(state.tasks) == 0 }}", "icon": "check", "title": "All clear", "label": "No tasks — add one above." }
    ]
  }
}
