{
  "qorm": "0.1",
  "type": "test",
  "name": "login test",
  "scene": {
    "type": "scene",
    "id": "login",
    "state": { "loginResult": null },
    "root": {
      "type": "column",
      "id": "root",
      "children": [
        {
          "type": "button",
          "id": "login_button",
          "text": "Login",
          "on": {
            "press": {
              "type": "host.call",
              "capability": "network.request",
              "input": { "method": "POST", "url": "https://example.invalid/login", "body": { "username": "demo" } },
              "target": "loginResult"
            }
          }
        }
      ]
    }
  },
  "mocks": {
    "network.request": {
      "status": "succeeded",
      "result": {
        "ok": true,
        "user": { "name": "Ada" }
      }
    }
  },
  "steps": [
    {
      "type": "simulate_event",
      "target": { "id": "login_button" },
      "event": "press"
    }
  ],
  "assertions": [
    {
      "type": "state_eq",
      "path": "loginResult",
      "value": {
        "ok": true,
        "user": { "name": "Ada" }
      }
    }
  ]
}
