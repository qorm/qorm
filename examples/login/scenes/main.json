{
  "type": "scene",
  "id": "main",
  "root": {
    "type": "column",
    "id": "root",
    "style": {
      "background": "var(--bg)",
      "padding": 48
    },
    "layout": {
      "width": "fill",
      "height": "fill",
      "align": "center",
      "justify": "center"
    },
    "children": [
      {
        "type": "column",
        "id": "header",
        "style": { "margin": { "bottom": 32 } },
        "layout": { "align": "center" },
        "children": [
          {
            "type": "text",
            "id": "title",
            "text": "Welcome Back",
            "style": {
              "color": "var(--label)",
              "fontSize": 28,
              "fontWeight": 700
            }
          },
          {
            "type": "text",
            "id": "subtitle",
            "text": "Sign in to your QORM account",
            "style": {
              "color": "var(--label2)",
              "fontSize": 14,
              "margin": { "top": 8 }
            }
          }
        ]
      },
      {
        "type": "column",
        "id": "form",
        "layout": { "width": "fill" },
        "style": { "gap": 16 },
        "children": [
          {
            "type": "text",
            "id": "lbl_email",
            "text": "Email Address",
            "style": { "color": "var(--label)", "fontSize": 14, "fontWeight": 600 }
          },
          {
            "type": "input",
            "id": "input_email",
            "placeholder": "admin@qorm.dev",
            "style": {
              "background": "var(--fill)",
              "height": 48,
              "padding": { "left": 12, "right": 12 },
              "borderRadius": 8
            }
          },
          {
            "type": "text",
            "id": "lbl_pwd",
            "text": "Password",
            "style": { "color": "var(--label)", "fontSize": 14, "fontWeight": 600, "margin": { "top": 8 } }
          },
          {
            "type": "input",
            "id": "input_password",
            "placeholder": "••••••••",
            "secure": true,
            "style": {
              "background": "var(--fill)",
              "height": 48,
              "padding": { "left": 12, "right": 12 },
              "borderRadius": 8
            }
          }
        ]
      },
      {
        "type": "button",
        "id": "btn_login",
        "label": "Sign In",
        "style": {
          "background": "#4F46E5",
          "color": "var(--on-accent)",
          "height": 50,
          "borderRadius": 8,
          "margin": { "top": 32 },
          "width": "fill"
        },
        "onPress": {
          "type": "invoke",
          "name": "performLogin",
          "args": {
            "email": "admin@qorm.dev",
            "password": "secret"
          }
        }
      },
      {
        "type": "text",
        "id": "error_msg",
        "text": "{{state.errorMessage}}",
        "style": {
          "color": "var(--danger)",
          "fontSize": 13,
          "margin": { "top": 16 },
          "textAlign": "center"
        }
      }
    ]
  }
}
