# Copy to /etc/qorm/donors.env (chmod 600) and fill in. NEVER commit the real file.
# Get a Creator's Access Token from https://www.patreon.com/portal/registration/register-clients
export PATREON_ACCESS_TOKEN=your-creator-access-token
# optional — auto-discovered from the token if omitted:
# export PATREON_CAMPAIGN_ID=your-campaign-id
